LTEXT           "l₂, мм",IDC_STATIC,220,34,70,8
EDITTEXT        IDC_EDIT_HALF_L2,295,32,52,14,ES_AUTOHSCROLL
LTEXT           "l₃, мм",IDC_STATIC,220,54,70,8
EDITTEXT        IDC_EDIT_HALF_L3,295,52,52,14,ES_AUTOHSCROLL
LTEXT           "B ширина паза под луч, мм",IDC_STATIC,220,74,115,8
EDITTEXT        IDC_EDIT_HALF_FACE_B,295,72,52,14,ES_AUTOHSCROLL
LTEXT           "B₁, мм",IDC_STATIC,220,94,70,8
EDITTEXT        IDC_EDIT_HALF_FACE_B1,295,92,52,14,ES_AUTOHSCROLL
LTEXT           "r скругления, мм",IDC_STATIC,220,114,115,8
EDITTEXT        IDC_EDIT_HALF_R,295,112,52,14,ES_AUTOHSCROLL
LTEXT           "Губок (только чтение: от варианта, 2 или 3)",IDC_STATIC,220,134,180,8
EDITTEXT        IDC_EDIT_HALF_LUGS,295,132,52,14,ES_AUTOHSCROLL
LTEXT           "Таблица ГОСТ №",IDC_STATIC,220,154,115,8
EDITTEXT        IDC_EDIT_HALF_TABLEID,295,152,52,14,ES_AUTOHSCROLL | ES_READONLY
LTEXT           "Проверка: L₁ ≥ l; D > d; d₁ > d. Число губок должно совпадать со звездой (исп.1 → 2, исп.2 → 3).",IDC_STATIC,14,180,390,22
END
IDD_SPIDER_PARAMS_DLG DIALOGEX 0, 0, 320, 268
