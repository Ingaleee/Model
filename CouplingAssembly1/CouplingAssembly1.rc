IDD_ASSEMBLY_PARAMS_DLG DIALOGEX 0, 0, 320, 306
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Шаг 1 из 4 — параметры сборки"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
DEFPUSHBUTTON   "ОК — сохранить и дальше",IDOK,175,285,84,14
PUSHBUTTON      "Отмена",IDCANCEL,263,285,50,14
LTEXT           "Начните отсюда: введите значения слева, затем кнопку подстановки из ГОСТ, проверьте серые поля — ОК. Дальше — пункты 2…4 в меню «Задание».",IDC_STATIC,14,8,290,26
LTEXT           "Момент Мкр, Н·м",IDC_STATIC,14,40,95,8
EDITTEXT        IDC_EDIT_ASSEMBLY_TORQUE,115,38,56,14,ES_AUTOHSCROLL
LTEXT           "Исполнение ГОСТ и число лучей задаются только номером варианта (см. ниже): 2 и 5 → исп.1, 4 луча; 1,3,4,6,7,8 → исп.2, 6 лучей.",IDC_STATIC,14,56,290,22
LTEXT           "Исполнение (только чтение, от варианта)",IDC_STATIC,14,82,170,8
EDITTEXT        IDC_EDIT_ASSEMBLY_EXECUTION,115,80,56,14,ES_AUTOHSCROLL | ES_READONLY
LTEXT           "Диаметр вала 1, мм → полумуфта 1",IDC_STATIC,14,104,170,8
EDITTEXT        IDC_EDIT_ASSEMBLY_SHAFT1,115,102,56,14,ES_AUTOHSCROLL
LTEXT           "Диаметр вала 2, мм → полумуфта 2",IDC_STATIC,14,126,170,8
EDITTEXT        IDC_EDIT_ASSEMBLY_SHAFT2,115,124,56,14,ES_AUTOHSCROLL
LTEXT           "Вариант задания 1…8 (от него — исполнение и 4 или 6 лучей)",IDC_STATIC,14,148,200,8
EDITTEXT        IDC_EDIT_ASSEMBLY_VARIANT,115,146,56,14,ES_AUTOHSCROLL
PUSHBUTTON      "Подставить L, D₁, n, m, b₁ из табл. 21.3.1",IDC_BTN_ASM_FROM_GOST,14,166,200,14
LTEXT           "L, мм (из ГОСТ)",IDC_STATIC,14,190,95,8
EDITTEXT        IDC_EDIT_ASM_DER_L,115,188,56,14,ES_AUTOHSCROLL | ES_READONLY
LTEXT           "D₁, мм",IDC_STATIC,14,212,95,8
EDITTEXT        IDC_EDIT_ASM_DER_D1,115,210,56,14,ES_AUTOHSCROLL | ES_READONLY
LTEXT           "n max, об/мин",IDC_STATIC,14,234,95,8
EDITTEXT        IDC_EDIT_ASM_DER_NMAX,115,232,56,14,ES_AUTOHSCROLL | ES_READONLY
LTEXT           "m, кг",IDC_STATIC,190,190,40,8
EDITTEXT        IDC_EDIT_ASM_DER_MASS,235,188,56,14,ES_AUTOHSCROLL | ES_READONLY
LTEXT           "b₁, мм",IDC_STATIC,190,212,40,8
EDITTEXT        IDC_EDIT_ASM_DER_B1,235,210,56,14,ES_AUTOHSCROLL | ES_READONLY
LTEXT           "Полумуфты 1 и 2 — две отдельные детали под два вала. Число губок совпадает с исполнением (2 или 3).",IDC_STATIC,14,254,290,22
END

